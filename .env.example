# Copie este arquivo para .env e preencha com seus valores reais
# cp .env.example .env

# ─── Banco de Dados (Oracle) ──────────────────────────────────────────────────
# Formato: Data Source=(...);User Id=SEU_USUARIO;Password=SUA_SENHA;...
ConnectionStrings__UrbansenseAPI=Data Source=(DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=oracle.fiap.com.br)(PORT=1521))(CONNECT_DATA=(SERVICE_NAME=orcl)));User Id=SEU_RM;Password=SUA_SENHA;Connection Timeout=120;Incr Pool Size=5;Max Pool Size=20;

# ─── JWT (Autenticação) ───────────────────────────────────────────────────────
# Secret: chave forte e aleatória, mínimo 32 caracteres
Jwt__Secret=sua-chave-secreta-muito-longa-e-segura-aqui
Jwt__Issuer=UrbansenseAPI
Jwt__Audience=UrbansenseClients
Jwt__ExpiryHours=24

# ─── OpenWeather API ──────────────────────────────────────────────────────────
# Obtenha sua chave em: https://openweathermap.org/api
OpenWeather__ApiKey=sua-openweather-api-key-aqui
OpenWeather__BaseUrl=https://api.openweathermap.org

# ─── OpenAI API ───────────────────────────────────────────────────────────────
# Obtenha sua chave em: https://platform.openai.com/api-keys
OpenAI__ApiKey=sk-proj-sua-openai-api-key-aqui
